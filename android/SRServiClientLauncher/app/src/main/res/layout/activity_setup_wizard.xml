<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="SRServi"
        android:textColor="@color/accent"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Configuración inicial"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Progreso -->
    <TextView
        android:id="@+id/tvStepProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:textColor="@color/accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginBottom="20dp"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@color/divider"
        android:max="4"
        android:progress="1" />

    <!-- Tarjeta del paso actual -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="32dp">

            <!-- Icono del paso -->
            <TextView
                android:id="@+id/tvStepIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="52sp"
                android:layout_marginBottom="20dp" />

            <!-- Título del paso -->
            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvStepDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="5dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botón de acción principal -->
    <Button
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/accent"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.04" />

    <!-- Botón omitir (solo para pasos opcionales) -->
    <Button
        android:id="@+id/btnSkip"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:text="Omitir este paso"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
