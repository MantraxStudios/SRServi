<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SRServi Pay"
            android:textSize="30sp"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test de Pagos — TUU DEV"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monto (CLP)"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAmount"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxStrokeColor="@color/gold"
            app:hintTextColor="@color/gold"
            app:boxStrokeWidth="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej: 10000"
                android:inputType="number"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Payment Method -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Método de Pago"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rgMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/rbMethodPrompt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Preguntar"
                android:textColor="@color/white"
                android:buttonTint="@color/gold" />

            <RadioButton
                android:id="@+id/rbMethodCredit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Crédito"
                android:textColor="@color/white"
                android:buttonTint="@color/gold" />

            <RadioButton
                android:id="@+id/rbMethodDebit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Débito"
                android:textColor="@color/white"
                android:buttonTint="@color/gold"
                android:checked="true" />
        </RadioGroup>

        <!-- Tip -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Propina"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rgTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <RadioButton
                android:id="@+id/rbTipNone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sin propina"
                android:textColor="@color/white"
                android:buttonTint="@color/gold"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbTipPrompt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Preguntar"
                android:textColor="@color/white"
                android:buttonTint="@color/gold" />
        </RadioGroup>

        <!-- Pay Button -->
        <Button
            android:id="@+id/btnPay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="INICIAR COBRO"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/gold"
            android:layout_marginBottom="28dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_dark"
            android:layout_marginBottom="16dp" />

        <!-- Result Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESULTADO"
            android:textColor="@color/gold"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin resultado aún"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="14dp"
            android:background="@color/surface_dark"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
