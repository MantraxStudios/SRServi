<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SRServi" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="SellButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">24dp</item>
    </style>

    <style name="SettingsButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">28dp</item>
        <item name="strokeColor">@color/gold</item>
        <item name="android:textColor">@color/gold</item>
        <item name="iconTint">@color/gold</item>
    </style>
</resources>
